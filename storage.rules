rules_version = '2';

// Production-shaped skeleton (questions/solutions paths land fully in Phase
// 3+). Path conventions:
//   /orgs/{organizationId}/questions/{ownerId}/{questionId}/{fileName}
//   /orgs/{organizationId}/solutions/{authorId}/{solutionId}/{fileName}
//   /users/{userId}/avatar/{fileName}
//
// Storage Rules' firestore.get() is unsafe to depend on for access checks
// — a previous phase reproduced it throwing `EvaluationException: Null
// value error` on real requests (see tests/integration/storage.rules.test.ts
// history), which made every getDownloadURL() fail, including for the
// file's own owner. So visibility is encoded directly in the Storage path
// instead of being looked up: every access-level check below is a path
// segment comparison, never a cross-service call.
service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function organizationId() {
      return request.auth.token.organizationId;
    }

    function isImageOrPdf() {
      return request.resource.contentType.matches('image/.*')
          || request.resource.contentType == 'application/pdf';
    }

    function isUnder10MB() {
      return request.resource.size < 10 * 1024 * 1024;
    }

    match /orgs/{org}/questions/{ownerId}/{questionId}/{fileName} {
      allow read: if isSignedIn() && organizationId() == org;
      allow write: if isSignedIn() && organizationId() == org && uid() == ownerId
                   && isImageOrPdf() && isUnder10MB();
    }

    match /orgs/{org}/solutions/{authorId}/{solutionId}/{fileName} {
      allow read: if isSignedIn() && organizationId() == org;
      allow write: if isSignedIn() && organizationId() == org && uid() == authorId
                   && isImageOrPdf() && isUnder10MB();
    }

    // Phase 6: {accessLevel} is 'public' or 'private', matching
    // src/services/storage/questionImages.ts's upload path construction
    // (derived from the question's chosen visibility — Firestore's 'class'
    // visibility collapses to the 'private' access level here too, since
    // it currently has no real membership check and is owner-only-readable
    // in firestore.rules, same as private). Public images are visible to
    // any authenticated user; private/class images stay owner-only.
    match /questions/public/{ownerId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && uid() == ownerId
                   && isImageOrPdf() && isUnder10MB();
    }

    match /questions/private/{ownerId}/{fileName} {
      allow read: if isSignedIn() && uid() == ownerId;
      allow write: if isSignedIn() && uid() == ownerId
                   && isImageOrPdf() && isUnder10MB();
    }

    // Phase 6: {accessLevel} mirrors the parent question's, same reasoning
    // as questions/{accessLevel}/... above — an answer image is readable
    // by whoever could read the question, without ever asking Storage to
    // cross-reference Firestore. The client already has the parent
    // Question (Question Detail screen) when uploading an answer, so it
    // can supply this segment directly — see uploadAnswerImage.
    match /answers/public/{questionId}/{ownerId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && uid() == ownerId
                   && isImageOrPdf() && isUnder10MB();
    }

    match /answers/private/{questionId}/{ownerId}/{fileName} {
      allow read: if isSignedIn() && uid() == ownerId;
      allow write: if isSignedIn() && uid() == ownerId
                   && isImageOrPdf() && isUnder10MB();
    }

    match /users/{userId}/avatar/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && uid() == userId
                   && request.resource.contentType.matches('image/.*')
                   && request.resource.size < 5 * 1024 * 1024;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
