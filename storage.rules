rules_version = '2';

// Production-shaped skeleton (questions/solutions paths land fully in Phase
// 3+). Path conventions:
//   /orgs/{organizationId}/questions/{ownerId}/{questionId}/{fileName}
//   /orgs/{organizationId}/solutions/{authorId}/{solutionId}/{fileName}
//   /users/{userId}/avatar/{fileName}
service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function organizationId() {
      return request.auth.token.organizationId;
    }

    // Cross-references the Firestore question doc so answer-image access
    // follows the exact same rule as the question itself (private ->
    // owner only; otherwise -> same org). Mirrors canReadQuestionData in
    // firestore.rules — keep both in sync if question visibility rules
    // ever change.
    function questionData(questionId) {
      return firestore.get(/databases/(default)/documents/questions/$(questionId)).data;
    }

    function canReadQuestionData(data) {
      return data.visibility == 'private' && uid() == data.ownerId ||
             data.visibility != 'private' && organizationId() == data.organizationId;
    }

    function isImageOrPdf() {
      return request.resource.contentType.matches('image/.*')
          || request.resource.contentType == 'application/pdf';
    }

    function isUnder10MB() {
      return request.resource.size < 10 * 1024 * 1024;
    }

    match /orgs/{org}/questions/{ownerId}/{questionId}/{fileName} {
      allow read: if isSignedIn() && organizationId() == org;
      allow write: if isSignedIn() && organizationId() == org && uid() == ownerId
                   && isImageOrPdf() && isUnder10MB();
    }

    match /orgs/{org}/solutions/{authorId}/{solutionId}/{fileName} {
      allow read: if isSignedIn() && organizationId() == org;
      allow write: if isSignedIn() && organizationId() == org && uid() == authorId
                   && isImageOrPdf() && isUnder10MB();
    }

    // Phase 3 MVP feed uploads. Unlike /orgs/{org}/questions/..., this path
    // has no org segment — the /orgs/ scheme can never admit a student with
    // organizationId == null (a path segment can never equal a real null
    // claim), and most students have no organization yet.
    //
    // Known limitation: this path has no questionId segment, only ownerId,
    // so — unlike answers/{questionId}/{ownerId}/{fileName} below — Storage
    // has no way to look up *which* question a file belongs to and check
    // that specific question's visibility. The safest rule reachable
    // without changing the upload path (out of scope this phase) is
    // owner-only read, which happens to be exactly correct today: every
    // question is created private, and a private question is only ever
    // readable by its own owner anyway (see firestore.rules). If a future
    // phase makes questions visible to more than their owner (class/friends
    // visibility), this path will need a questionId segment added so this
    // rule can do the same firestore.get() cross-check the answers path
    // does.
    match /questions/{ownerId}/{fileName} {
      allow read: if isSignedIn() && uid() == ownerId;
      allow write: if isSignedIn() && uid() == ownerId
                   && isImageOrPdf() && isUnder10MB();
    }

    // Phase 4/5: path includes questionId, so — unlike questions/{ownerId}/
    // {fileName} above — reads can be gated on the actual related
    // question's visibility, same as Firestore's answers/{answerId} rule.
    match /answers/{questionId}/{ownerId}/{fileName} {
      allow read: if isSignedIn() && canReadQuestionData(questionData(questionId));
      allow write: if isSignedIn() && uid() == ownerId
                   && isImageOrPdf() && isUnder10MB();
    }

    match /users/{userId}/avatar/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && uid() == userId
                   && request.resource.contentType.matches('image/.*')
                   && request.resource.size < 2 * 1024 * 1024;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
