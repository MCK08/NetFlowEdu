rules_version = '2';

// Production-shaped skeleton (questions/solutions paths land fully in Phase
// 3+). Path conventions:
//   /orgs/{organizationId}/questions/{ownerId}/{questionId}/{fileName}
//   /orgs/{organizationId}/solutions/{authorId}/{solutionId}/{fileName}
//   /users/{userId}/avatar/{fileName}
service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function organizationId() {
      return request.auth.token.organizationId;
    }

    function isImageOrPdf() {
      return request.resource.contentType.matches('image/.*')
          || request.resource.contentType == 'application/pdf';
    }

    function isUnder10MB() {
      return request.resource.size < 10 * 1024 * 1024;
    }

    match /orgs/{org}/questions/{ownerId}/{questionId}/{fileName} {
      allow read: if isSignedIn() && organizationId() == org;
      allow write: if isSignedIn() && organizationId() == org && uid() == ownerId
                   && isImageOrPdf() && isUnder10MB();
    }

    match /orgs/{org}/solutions/{authorId}/{solutionId}/{fileName} {
      allow read: if isSignedIn() && organizationId() == org;
      allow write: if isSignedIn() && organizationId() == org && uid() == authorId
                   && isImageOrPdf() && isUnder10MB();
    }

    // Phase 3 MVP feed uploads. Unlike /orgs/{org}/questions/..., this path
    // has no org segment — the /orgs/ scheme can never admit a student with
    // organizationId == null (a path segment can never equal a real null
    // claim), and most students have no organization yet. Owner-only read
    // is exactly correct today: every question is created private, and a
    // private question is only ever readable by its own owner anyway (see
    // firestore.rules).
    match /questions/{ownerId}/{fileName} {
      allow read: if isSignedIn() && uid() == ownerId;
      allow write: if isSignedIn() && uid() == ownerId
                   && isImageOrPdf() && isUnder10MB();
    }

    // Owner-only, same reasoning as questions/{ownerId}/{fileName} above —
    // NOT a Firestore cross-service lookup. An earlier version of this rule
    // called firestore.get(/databases/(default)/documents/questions/$(questionId))
    // to check the parent question's real visibility/organizationId before
    // allowing a read, so that a future non-private question could someday
    // be readable by more than its owner. In practice that get() call threw
    // `EvaluationException: Null value error` on real requests — reproduced
    // in tests/integration/storage.rules.test.ts against the exact
    // production path/uid/contentType — which made every getDownloadURL()
    // on an answer image fail with storage/unauthorized, including for the
    // image's own owner. Storage Rules' firestore.get() is a cross-service
    // call outside this ruleset's own consistency/availability guarantees;
    // it is not safe to depend on for a check this basic. Since every
    // question is created private today, owner-only read via the path
    // segment alone is both correct and exception-proof — it never touches
    // Firestore, so it cannot fail this way. If a future phase makes
    // questions visible to more than their owner, mirror that visibility
    // into the Storage path itself (e.g. an org segment on this path, like
    // /orgs/{org}/questions/... above) rather than reintroducing a
    // Storage-to-Firestore get().
    match /answers/{questionId}/{ownerId}/{fileName} {
      allow read: if isSignedIn() && uid() == ownerId;
      allow write: if isSignedIn() && uid() == ownerId
                   && isImageOrPdf() && isUnder10MB();
    }

    match /users/{userId}/avatar/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && uid() == userId
                   && request.resource.contentType.matches('image/.*')
                   && request.resource.size < 2 * 1024 * 1024;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
