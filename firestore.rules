rules_version = '2';

// Production-shaped ruleset. Every rule below is deny-by-default; loosen
// only with a named reason in the commit message.
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Helpers -----------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    // role/organizationId are mirrored onto the user's custom claims by
    // Cloud Functions (onUserCreate trigger, adminSetUserRole callable)
    // whenever users/{uid} is created or promoted, so rules can check
    // claims directly (fast, no extra read) instead of fetching the doc.
    function role() {
      return request.auth.token.role;
    }

    function organizationId() {
      return request.auth.token.organizationId;
    }

    function isRole(r) {
      return isSignedIn() && role() == r;
    }

    function isPlatformAdmin() {
      return isRole('platform_admin');
    }

    function isOrgAdmin() {
      return isRole('organization_admin');
    }

    function isTeacher() {
      return isRole('teacher');
    }

    function isStudent() {
      return isRole('student');
    }

    function sameOrg(resourceOrgId) {
      return isSignedIn() && organizationId() == resourceOrgId;
    }

    function isOwner(resourceOwnerId) {
      return isSignedIn() && uid() == resourceOwnerId;
    }

    // Shared by questions/{questionId}'s own read rule AND anything that
    // gates access on "can the caller read this question" (answers,
    // questionComments), so they can never drift out of sync.
    //
    // 'class' visibility is readable by any member of the target class
    // (student or teacher) — see classes/{classId}/members/{uid} below,
    // written exclusively by the join/create/remove Cloud Functions.
    function canReadQuestionData(data) {
      return data.visibility == 'private' && isOwner(data.ownerId) ||
             data.visibility == 'public' && isSignedIn() ||
             data.visibility == 'class' && isClassMember(data.classId);
    }

    function questionData(qid) {
      return get(/databases/$(database)/documents/questions/$(qid)).data;
    }

    // ---- classes helpers -------------------------------------------------

    function isClassMember(classId) {
      return isSignedIn()
          && exists(/databases/$(database)/documents/classes/$(classId)/members/$(uid()));
    }

    function classData(classId) {
      return get(/databases/$(database)/documents/classes/$(classId)).data;
    }

    // ---- users/{userId} -----------------------------------------------
    //
    // Server-managed fields — role, organizationId, totalPoints,
    // weeklyPoints, accountStatus, createdAt, uid, email — are set only by
    // Cloud Functions (Admin SDK bypasses these rules entirely). The owner
    // may read their whole profile (nothing here needs to be hidden from
    // them) but may only ever write displayName / photoURL / updatedAt.
    //
    // This document contains email/accountStatus, so it stays strictly
    // owner-only — never readable cross-user. Anything another user is
    // allowed to see about this account lives in publicProfiles/{uid}
    // instead (safe-field copy, see below).

    match /users/{userId} {
      allow read: if isOwner(userId);

      // Only the Cloud Functions onUserCreate trigger creates this
      // document (via the Admin SDK, which isn't subject to these rules),
      // so client-initiated creates are always denied — this is not a
      // gap, it's the intended path.
      allow create: if false;

      allow update: if isOwner(userId)
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['displayName', 'photoURL', 'updatedAt'])
                    && request.resource.data.uid == resource.data.uid
                    && request.resource.data.email == resource.data.email
                    && request.resource.data.role == resource.data.role
                    && request.resource.data.organizationId == resource.data.organizationId
                    && request.resource.data.totalPoints == resource.data.totalPoints
                    && request.resource.data.weeklyPoints == resource.data.weeklyPoints
                    && request.resource.data.accountStatus == resource.data.accountStatus
                    && request.resource.data.createdAt == resource.data.createdAt
                    // onboardingStatus/requestedRole are exclusively
                    // Cloud-Function-managed (see
                    // functions/src/onboarding/{initializeOnboarding,completeOnboarding}.ts).
                    // Every account created before these fields existed has
                    // no such keys at all, and plain `==` on a missing map
                    // key throws ("Property ... is undefined"), not just
                    // evaluates falsy — so this uses .get(key, default) to
                    // treat "absent" as a real, comparable value instead. A
                    // client update is only ever allowed if both fields stay
                    // exactly as they were (present-and-equal, or
                    // absent-and-still-absent) — a client can never set,
                    // clear, or backdate onboarding state, or swap
                    // requestedRole, themselves.
                    && request.resource.data.get('onboardingStatus', null)
                       == resource.data.get('onboardingStatus', null)
                    && request.resource.data.get('requestedRole', null)
                       == resource.data.get('requestedRole', null);

      allow delete: if false;
    }

    // ---- users/{uid}/savedQuestions/{questionId} ------------------------
    // Personal bookmark list. Unlike likes, there's no shared counter to
    // protect (a bookmark only affects the owner's own view), so this is
    // fully client-writable — same trust level as the user's own displayName
    // edit, just a different field. Denormalized snapshot written at save
    // time by the client (see saveQuestion) so listing never needs an extra
    // read per item.

    match /users/{uid}/savedQuestions/{questionId} {
      allow read, write: if isOwner(uid);
    }

    // ---- publicProfiles/{uid} -------------------------------------------
    //
    // Safe-field mirror of users/{uid} — never email/accountStatus/
    // moderation data (see functions/src/profiles/syncPublicProfile.ts,
    // the only writer, triggered on every users/{uid} write). Readable by
    // any authenticated user; this is what makes cross-user username/
    // avatar/points display possible without exposing the owner-only
    // users/{uid} document.

    match /publicProfiles/{uid} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ---- questions/{questionId} ----------------------------------------
    // visibility: "private" | "public" | "class"

    match /questions/{questionId} {
      // isOwner(...) is listed first, and separately from
      // canReadQuestionData, on purpose: Firestore's query-provability
      // check is purely syntactic, based on what the *query itself*
      // constrains, never on what's actually stored. getOwnQuestionsPage's
      // query (`where('ownerId','==',uid())`, no visibility filter) lets
      // Firestore statically prove this left-hand branch always holds for
      // every document the query could return (because the query's own
      // equality filter already pins ownerId), so it never needs to
      // inspect `visibility` at all for that query. Folding this into
      // canReadQuestionData instead (visibility-gated on every branch,
      // including the owner one) makes the *whole* rule depend on
      // `visibility`, which the query doesn't constrain — Firestore then
      // refuses to run the query at all: "Property visibility is
      // undefined on object" (reproduced with the emulator against this
      // exact query shape). This also matches questions.ts's own doc
      // comment on getOwnQuestionsPage ("owner can always read their own
      // regardless of visibility"), which the old rule never actually
      // guaranteed at the query level, only for single-document get()s.
      allow read: if isSignedIn() && (isOwner(resource.data.ownerId) || canReadQuestionData(resource.data));

      // private/public: any signed-in user, no classId. 'class': only the
      // class's own teacher may post into it — checked against the class
      // doc itself (teacherId + organizationId), not just the caller's own
      // claims, so a teacher can never post into a class they don't own
      // even if organizationId happens to match.
      allow create: if isSignedIn()
                    && request.resource.data.ownerId == uid()
                    && request.resource.data.organizationId == organizationId()
                    && request.resource.data.likeCount == 0
                    && request.resource.data.commentCount == 0
                    && request.resource.data.answerCount == 0
                    && (
                         request.resource.data.visibility in ['private', 'public']
                         && request.resource.data.classId == null
                         ||
                         request.resource.data.visibility == 'class'
                         && isTeacher()
                         && request.resource.data.classId is string
                         && classData(request.resource.data.classId).teacherId == uid()
                         && classData(request.resource.data.classId).organizationId == organizationId()
                       );

      // answerCount/likeCount/commentCount are maintained only by trusted
      // Cloud Functions (Admin SDK bypasses these rules) — don't trust the
      // client to increment any of them. visibility is immutable once
      // created (no "constrained transition" matrix needed if it just
      // never changes).
      allow update: if isOwner(resource.data.ownerId)
                    && request.resource.data.ownerId == resource.data.ownerId
                    && request.resource.data.visibility == resource.data.visibility
                    && request.resource.data.answerCount == resource.data.answerCount
                    && request.resource.data.likeCount == resource.data.likeCount
                    && request.resource.data.commentCount == resource.data.commentCount;

      allow delete: if isOwner(resource.data.ownerId) || isTeacher() || isOrgAdmin();
    }

    // ---- organizations/{organizationId} ---------------------------------
    // A teacher's personal workspace, created exclusively by
    // completeOnboarding (Admin SDK) when a new account picks "teacher" at
    // registration — see functions/src/onboarding/completeOnboarding.ts.
    // Never client-writable, matching every other server-managed collection
    // in this file. Read is limited to the owner — nothing today needs a
    // student or another teacher to read someone else's organization doc
    // directly (class access is already gated by class membership, not by
    // reading the organization itself).
    match /organizations/{organizationId} {
      allow read: if isOwner(resource.data.ownerId);
      allow write: if false;
    }

    // ---- classes/{classId} ---------------------------------------------
    // Every field here (joinCode especially) is Cloud-Function-managed —
    // see functions/src/classes/. A client `create`/`update` would let a
    // teacher mint their own join code (bypassing the uniqueness reservation
    // in classJoinCodes/{code}) or silently rewrite memberCount, so all
    // writes are denied and funneled through createClass /
    // regenerateClassJoinCode / joinClassByCode / leaveClass /
    // removeClassMember instead — same pattern as usernames/{username}.
    //
    // Read is restricted to the owning teacher or a current member (not
    // "anyone in the org") because the document contains the join code
    // itself: any org member being able to read it would let them join
    // without ever being given the code, defeating its purpose. A member
    // already has the code (they used it to join), so exposing it back to
    // them leaks nothing new.
    match /classes/{classId} {
      allow read: if isSignedIn() && (resource.data.teacherId == uid() || isClassMember(classId));
      allow write: if false;
    }

    // ---- classes/{classId}/members/{memberUid} --------------------------
    // Membership is exclusively Cloud-Function-managed (joinClassByCode /
    // leaveClass / removeClassMember) so a student can never add themselves
    // (or anyone else) directly, and memberCount on the parent class can
    // never desync from the actual member docs. Read is limited to the
    // member's own row or the owning teacher (member list) — students don't
    // get a roster of their classmates in this phase, matching the spec's
    // "view class members" being a teacher-only capability.
    match /classes/{classId}/members/{memberUid} {
      allow read: if isSignedIn() && (isOwner(memberUid) || classData(classId).teacherId == uid());
      allow write: if false;
    }

    // ---- friendships/{friendshipId} -------------------------------------

    match /friendships/{friendshipId} {
      allow read: if isSignedIn() && uid() in resource.data.participantIds;
      allow create: if isSignedIn() && uid() in request.resource.data.participantIds;
      allow update, delete: if isSignedIn() && uid() in resource.data.participantIds;
    }

    // ---- solutions/{solutionId} ------------------------------------------

    match /solutions/{solutionId} {
      allow read: if sameOrg(resource.data.organizationId);
      allow create: if isSignedIn() && request.resource.data.authorId == uid();
      allow update: if isOwner(resource.data.authorId)
                    && request.resource.data.verified == resource.data.verified;
      allow delete: if isOwner(resource.data.authorId) || isTeacher();
    }

    // ---- leaderboards/{leaderboardId} -------------------------------------
    // Written exclusively by Cloud Functions using the Admin SDK, which
    // bypasses these rules entirely — clients never get write access.

    match /leaderboards/{leaderboardId} {
      allow read: if sameOrg(resource.data.organizationId);
      allow write: if false;
    }

    // ---- answers/{answerId} --------------------------------------------
    // An answer is readable by anyone who can read its parent question.

    match /answers/{answerId} {
      allow read: if isSignedIn()
                  && exists(/databases/$(database)/documents/questions/$(resource.data.questionId))
                  && canReadQuestionData(questionData(resource.data.questionId));

      allow create: if isSignedIn()
                    && request.resource.data.ownerId == uid()
                    && request.resource.data.method in ['photo', 'drawing']
                    && request.resource.data.createdAt == request.time
                    && request.resource.data.imageUrl is string
                    && request.resource.data.imageUrl.size() > 0
                    && request.resource.data.likeCount == 0
                    && exists(/databases/$(database)/documents/questions/$(request.resource.data.questionId))
                    && canReadQuestionData(questionData(request.resource.data.questionId));

      // likeCount is maintained only by toggleAnswerLike (Admin SDK). No
      // other edit-answer feature exists, so nothing else may ever change.
      allow update: if isOwner(resource.data.ownerId)
                    && request.resource.data.ownerId == resource.data.ownerId
                    && request.resource.data.questionId == resource.data.questionId
                    && request.resource.data.method == resource.data.method
                    && request.resource.data.imageUrl == resource.data.imageUrl
                    && request.resource.data.createdAt == resource.data.createdAt;

      // Only the answer's own owner may delete it — never anyone else's,
      // including the question's owner.
      allow delete: if isOwner(resource.data.ownerId);
    }

    // ---- questionLikes/{likeId} -----------------------------------------
    // Doc id: `${questionId}_${userId}` (deterministic — see
    // functions/src/social/toggleQuestionLike.ts). Written exclusively by
    // that callable (Admin SDK, transactional with questions/{id}.likeCount)
    // so a client can never fake a like or desync the count. Clients may
    // read only their own like record, to render "did I like this".
    //
    // `resource == null` guards a get() on a like the caller hasn't cast
    // yet (the common case — most question/answer pairs have none): for a
    // non-existent document `resource` is null, and dereferencing
    // `resource.data` on it is a rule-evaluation error, which Firestore
    // surfaces to the client as permission-denied (confirmed on a real
    // device — see getMyLikeState's "missing doc just means not liked yet"
    // comment, which was wrong before this fix). Checking `resource == null`
    // first lets a missing like resolve to "not found" the same as any
    // other client read, before ever touching `.data`.

    match /questionLikes/{likeId} {
      allow read: if resource == null || isOwner(resource.data.userId);
      allow write: if false;
    }

    // ---- answerLikes/{likeId} -------------------------------------------
    // Same pattern as questionLikes — see toggleAnswerLike.ts.

    match /answerLikes/{likeId} {
      allow read: if resource == null || isOwner(resource.data.userId);
      allow write: if false;
    }

    // ---- questionComments/{commentId} -----------------------------------
    // Readable by anyone who can read the related question (same
    // canReadQuestionData indirection as answers). No edit feature this
    // phase — update is fully denied. Only the comment's own owner may
    // delete it (admin moderation deferred to a later phase, per spec).

    match /questionComments/{commentId} {
      allow read: if isSignedIn()
                  && exists(/databases/$(database)/documents/questions/$(resource.data.questionId))
                  && canReadQuestionData(questionData(resource.data.questionId));

      allow create: if isSignedIn()
                    && request.resource.data.ownerId == uid()
                    && request.resource.data.status == 'active'
                    && request.resource.data.createdAt == request.time
                    && request.resource.data.text is string
                    && request.resource.data.text.size() > 0
                    && request.resource.data.text.size() <= 500
                    && exists(/databases/$(database)/documents/questions/$(request.resource.data.questionId))
                    && canReadQuestionData(questionData(request.resource.data.questionId));

      allow update: if false;
      allow delete: if isOwner(resource.data.ownerId);
    }

    // ---- usernames/{username} ------------------------------------------
    // Written exclusively by the setUsername Cloud Function (Admin SDK,
    // bypasses these rules) as a uniqueness reservation. Never read or
    // written by clients directly.

    // ---- classJoinCodes/{code} ------------------------------------------
    // Same uniqueness-reservation pattern as usernames/{username} above —
    // written exclusively by createClass / regenerateClassJoinCode (Admin
    // SDK). Never read or written by clients; joinClassByCode resolves a
    // code to a classId server-side instead of the client querying this
    // collection directly, so a client can't enumerate valid codes.

    // Default deny for anything not explicitly matched above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
