rules_version = '2';

// Production-shaped ruleset. Every rule below is deny-by-default; loosen
// only with a named reason in the commit message.
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Helpers -----------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    // role/organizationId are mirrored onto the user's custom claims by
    // Cloud Functions (onUserCreate trigger, adminSetUserRole callable)
    // whenever users/{uid} is created or promoted, so rules can check
    // claims directly (fast, no extra read) instead of fetching the doc.
    function role() {
      return request.auth.token.role;
    }

    function organizationId() {
      return request.auth.token.organizationId;
    }

    function isRole(r) {
      return isSignedIn() && role() == r;
    }

    function isPlatformAdmin() {
      return isRole('platform_admin');
    }

    function isOrgAdmin() {
      return isRole('organization_admin');
    }

    function isTeacher() {
      return isRole('teacher');
    }

    function isStudent() {
      return isRole('student');
    }

    function sameOrg(resourceOrgId) {
      return isSignedIn() && organizationId() == resourceOrgId;
    }

    function isOwner(resourceOwnerId) {
      return isSignedIn() && uid() == resourceOwnerId;
    }

    // Shared by questions/{questionId}'s own read rule AND anything that
    // gates access on "can the caller read this question" (answers,
    // questionComments), so they can never drift out of sync.
    //
    // 'class' has no real membership system yet (rosters aren't
    // implemented) — rather than fake membership, it's treated as
    // owner-only, same as private, until a real roster check exists. The
    // client-facing "Sınıf" visibility option is disabled to match (see
    // src/features/upload — "Sınıf özelliği yakında").
    function canReadQuestionData(data) {
      return data.visibility == 'private' && isOwner(data.ownerId) ||
             data.visibility == 'public' && isSignedIn() ||
             data.visibility == 'class' && isOwner(data.ownerId);
    }

    function questionData(qid) {
      return get(/databases/$(database)/documents/questions/$(qid)).data;
    }

    // ---- users/{userId} -----------------------------------------------
    //
    // Server-managed fields — role, organizationId, totalPoints,
    // weeklyPoints, accountStatus, createdAt, uid, email — are set only by
    // Cloud Functions (Admin SDK bypasses these rules entirely). The owner
    // may read their whole profile (nothing here needs to be hidden from
    // them) but may only ever write displayName / photoURL / updatedAt.
    //
    // This document contains email/accountStatus, so it stays strictly
    // owner-only — never readable cross-user. Anything another user is
    // allowed to see about this account lives in publicProfiles/{uid}
    // instead (safe-field copy, see below).

    match /users/{userId} {
      allow read: if isOwner(userId);

      // Only the Cloud Functions onUserCreate trigger creates this
      // document (via the Admin SDK, which isn't subject to these rules),
      // so client-initiated creates are always denied — this is not a
      // gap, it's the intended path.
      allow create: if false;

      allow update: if isOwner(userId)
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['displayName', 'photoURL', 'updatedAt'])
                    && request.resource.data.uid == resource.data.uid
                    && request.resource.data.email == resource.data.email
                    && request.resource.data.role == resource.data.role
                    && request.resource.data.organizationId == resource.data.organizationId
                    && request.resource.data.totalPoints == resource.data.totalPoints
                    && request.resource.data.weeklyPoints == resource.data.weeklyPoints
                    && request.resource.data.accountStatus == resource.data.accountStatus
                    && request.resource.data.createdAt == resource.data.createdAt;

      allow delete: if false;
    }

    // ---- publicProfiles/{uid} -------------------------------------------
    //
    // Safe-field mirror of users/{uid} — never email/accountStatus/
    // moderation data (see functions/src/profiles/syncPublicProfile.ts,
    // the only writer, triggered on every users/{uid} write). Readable by
    // any authenticated user; this is what makes cross-user username/
    // avatar/points display possible without exposing the owner-only
    // users/{uid} document.

    match /publicProfiles/{uid} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ---- questions/{questionId} ----------------------------------------
    // visibility: "private" | "public" | "class"

    match /questions/{questionId} {
      allow read: if isSignedIn() && canReadQuestionData(resource.data);

      // 'class' is schema-reserved but not creatable yet — see
      // canReadQuestionData's note. Only private/public are accepted.
      allow create: if isSignedIn()
                    && request.resource.data.ownerId == uid()
                    && request.resource.data.organizationId == organizationId()
                    && request.resource.data.visibility in ['private', 'public']
                    && request.resource.data.likeCount == 0
                    && request.resource.data.commentCount == 0
                    && request.resource.data.answerCount == 0;

      // answerCount/likeCount/commentCount are maintained only by trusted
      // Cloud Functions (Admin SDK bypasses these rules) — don't trust the
      // client to increment any of them. visibility is immutable once
      // created (no "constrained transition" matrix needed if it just
      // never changes).
      allow update: if isOwner(resource.data.ownerId)
                    && request.resource.data.ownerId == resource.data.ownerId
                    && request.resource.data.visibility == resource.data.visibility
                    && request.resource.data.answerCount == resource.data.answerCount
                    && request.resource.data.likeCount == resource.data.likeCount
                    && request.resource.data.commentCount == resource.data.commentCount;

      allow delete: if isOwner(resource.data.ownerId) || isTeacher() || isOrgAdmin();
    }

    // ---- classes/{classId} ---------------------------------------------

    match /classes/{classId} {
      allow read: if sameOrg(resource.data.organizationId);
      allow create: if isTeacher() && request.resource.data.organizationId == organizationId();
      allow update, delete: if isTeacher() && isOwner(resource.data.teacherId) || isOrgAdmin();
    }

    // ---- friendships/{friendshipId} -------------------------------------

    match /friendships/{friendshipId} {
      allow read: if isSignedIn() && uid() in resource.data.participantIds;
      allow create: if isSignedIn() && uid() in request.resource.data.participantIds;
      allow update, delete: if isSignedIn() && uid() in resource.data.participantIds;
    }

    // ---- solutions/{solutionId} ------------------------------------------

    match /solutions/{solutionId} {
      allow read: if sameOrg(resource.data.organizationId);
      allow create: if isSignedIn() && request.resource.data.authorId == uid();
      allow update: if isOwner(resource.data.authorId)
                    && request.resource.data.verified == resource.data.verified;
      allow delete: if isOwner(resource.data.authorId) || isTeacher();
    }

    // ---- leaderboards/{leaderboardId} -------------------------------------
    // Written exclusively by Cloud Functions using the Admin SDK, which
    // bypasses these rules entirely — clients never get write access.

    match /leaderboards/{leaderboardId} {
      allow read: if sameOrg(resource.data.organizationId);
      allow write: if false;
    }

    // ---- answers/{answerId} --------------------------------------------
    // An answer is readable by anyone who can read its parent question.

    match /answers/{answerId} {
      allow read: if isSignedIn()
                  && exists(/databases/$(database)/documents/questions/$(resource.data.questionId))
                  && canReadQuestionData(questionData(resource.data.questionId));

      allow create: if isSignedIn()
                    && request.resource.data.ownerId == uid()
                    && request.resource.data.method in ['photo', 'drawing']
                    && request.resource.data.createdAt == request.time
                    && request.resource.data.imageUrl is string
                    && request.resource.data.imageUrl.size() > 0
                    && request.resource.data.likeCount == 0
                    && exists(/databases/$(database)/documents/questions/$(request.resource.data.questionId))
                    && canReadQuestionData(questionData(request.resource.data.questionId));

      // likeCount is maintained only by toggleAnswerLike (Admin SDK). No
      // other edit-answer feature exists, so nothing else may ever change.
      allow update: if isOwner(resource.data.ownerId)
                    && request.resource.data.ownerId == resource.data.ownerId
                    && request.resource.data.questionId == resource.data.questionId
                    && request.resource.data.method == resource.data.method
                    && request.resource.data.imageUrl == resource.data.imageUrl
                    && request.resource.data.createdAt == resource.data.createdAt;

      // Only the answer's own owner may delete it — never anyone else's,
      // including the question's owner.
      allow delete: if isOwner(resource.data.ownerId);
    }

    // ---- questionLikes/{likeId} -----------------------------------------
    // Doc id: `${questionId}_${userId}` (deterministic — see
    // functions/src/social/toggleQuestionLike.ts). Written exclusively by
    // that callable (Admin SDK, transactional with questions/{id}.likeCount)
    // so a client can never fake a like or desync the count. Clients may
    // read only their own like record, to render "did I like this".

    match /questionLikes/{likeId} {
      allow read: if isOwner(resource.data.userId);
      allow write: if false;
    }

    // ---- answerLikes/{likeId} -------------------------------------------
    // Same pattern as questionLikes — see toggleAnswerLike.ts.

    match /answerLikes/{likeId} {
      allow read: if isOwner(resource.data.userId);
      allow write: if false;
    }

    // ---- questionComments/{commentId} -----------------------------------
    // Readable by anyone who can read the related question (same
    // canReadQuestionData indirection as answers). No edit feature this
    // phase — update is fully denied. Only the comment's own owner may
    // delete it (admin moderation deferred to a later phase, per spec).

    match /questionComments/{commentId} {
      allow read: if isSignedIn()
                  && exists(/databases/$(database)/documents/questions/$(resource.data.questionId))
                  && canReadQuestionData(questionData(resource.data.questionId));

      allow create: if isSignedIn()
                    && request.resource.data.ownerId == uid()
                    && request.resource.data.status == 'active'
                    && request.resource.data.createdAt == request.time
                    && request.resource.data.text is string
                    && request.resource.data.text.size() > 0
                    && request.resource.data.text.size() <= 500
                    && exists(/databases/$(database)/documents/questions/$(request.resource.data.questionId))
                    && canReadQuestionData(questionData(request.resource.data.questionId));

      allow update: if false;
      allow delete: if isOwner(resource.data.ownerId);
    }

    // ---- usernames/{username} ------------------------------------------
    // Written exclusively by the setUsername Cloud Function (Admin SDK,
    // bypasses these rules) as a uniqueness reservation. Never read or
    // written by clients directly.

    // Default deny for anything not explicitly matched above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
